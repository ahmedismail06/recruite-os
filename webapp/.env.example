# Only needed if you chose the Supabase storage backend (the webapp is Supabase-only).
# Copy this file to .env.local and fill in your own project's values. Never commit .env.local.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SECRET_KEY=paste-your-secret-key-here
# Shared password gating access to the deployed app (Basic Auth via proxy.ts).
# Required because Vercel's Hobby-plan deployment protection doesn't cover the production domain.
APP_PASSWORD=paste-a-strong-password-here
